   "type": "text",
   "x": 40,
   "y": 566,
   "width": 1619.99,
   "height": 15,
   "text": "Seerr sends requests to Sonarr and Radarr; Prowlarr feeds their indexers and FlareSolverr clears challenges. Grabs go to qBittorrent, whose only route out is Gluetun to Proton VPN. Finished files hard-link into the libraries Jellyfin serves back to the viewer.",
   "originalText": "Seerr sends requests to Sonarr and Radarr; Prowlarr feeds their indexers and FlareSolverr clears challenges. Grabs go to qBittorrent, whose only route out is Gluetun to Proton VPN. Finished files hard-link into the libraries Jellyfin serves back to the viewer.",
   "fontSize": 12,
   "fontFamily": 5,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "lineHeight": 1.25,
   "baseline": 11
  }
