   "type": "text",
   "x": 40,
   "y": 410,
   "width": 1827.56,
   "height": 15,
   "text": "Every change is additive first: stage the replacement beside the current key, verify from the key owner on each target, then retire. The Proxmox nodes share one cluster-backed authorized_keys, so only grey writes it. The two unreachable Windows hosts stay Unknown, never assumed clean.",
   "originalText": "Every change is additive first: stage the replacement beside the current key, verify from the key owner on each target, then retire. The Proxmox nodes share one cluster-backed authorized_keys, so only grey writes it. The two unreachable Windows hosts stay Unknown, never assumed clean.",
   "fontSize": 12,
   "fontFamily": 5,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "lineHeight": 1.25,
