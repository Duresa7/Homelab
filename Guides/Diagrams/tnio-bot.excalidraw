   "type": "text",
   "x": 40,
   "y": 372,
   "width": 1935.96,
   "height": 15,
   "text": "A Discord question reaches the bot, which calls the HTTP search service at /agent-answer; the service retrieves from the lore corpus and its source map. The sync job refreshes the corpus, and policy, corpus, and golden tests have to pass before a changed module is deployed and the answer cache is cleared.",
   "originalText": "A Discord question reaches the bot, which calls the HTTP search service at /agent-answer; the service retrieves from the lore corpus and its source map. The sync job refreshes the corpus, and policy, corpus, and golden tests have to pass before a changed module is deployed and the answer cache is cleared.",
   "fontSize": 12,
   "fontFamily": 5,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "lineHeight": 1.25,
   "baseline": 11
  }
