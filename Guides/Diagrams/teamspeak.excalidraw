   "type": "text",
   "x": 40,
   "y": 424,
   "width": 1895.11,
   "height": 15,
   "text": "Each public name resolves through a Cloudflare SRV record to a Playit relay, and the shared Playit agent forwards every voice port to its local UDP listener. The agent runs as its own project so a TeamSpeak restart doesn't drop the tunnels; TS3 Manager reaches the servers over local query ports only.",
   "originalText": "Each public name resolves through a Cloudflare SRV record to a Playit relay, and the shared Playit agent forwards every voice port to its local UDP listener. The agent runs as its own project so a TeamSpeak restart doesn't drop the tunnels; TS3 Manager reaches the servers over local query ports only.",
   "fontSize": 12,
   "fontFamily": 5,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "lineHeight": 1.25,
   "baseline": 11
  }
